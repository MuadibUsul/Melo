# apps/web environment — copy to apps/web/.env.local. NEVER commit real secrets.
# Server-only secrets must not be NEXT_PUBLIC_*. Over the migration these move
# behind apps/api; today the web app still calls MiniMax / Supabase directly.

# MiniMax (server-only)
MINIMAX_API_KEY=

# Supabase (optional; absent => local demo/mock mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (optional; absent => local mock storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

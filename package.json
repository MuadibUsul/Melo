{
  "name": "minimax-music-platform",
  "version": "0.1.0",
  "private": true,
  "description": "MiniMax 驱动的 AI 音乐生成与聆听平台 (monorepo)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "smoke:local-backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-local-backend.ps1",
    "smoke:minimax-live": "pnpm --filter @music/sdk-minimax build && node scripts/smoke/minimax-live-smoke.mjs",
    "smoke:minimax-live:music": "pnpm --filter @music/sdk-minimax build && node scripts/smoke/minimax-live-smoke.mjs --music",
    "smoke:minimax-live:music:local": "pnpm --filter @music/sdk-minimax build && node scripts/smoke/minimax-live-smoke.mjs --music --allow-local-provider",
    "smoke:minimax-live:optional": "pnpm --filter @music/sdk-minimax build && node scripts/smoke/minimax-live-smoke.mjs --skip-if-missing",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}

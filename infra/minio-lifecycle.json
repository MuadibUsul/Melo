{
  "LifecycleConfiguration": [
    {
      "ID": "expire-temp-uploads",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "temp/"
      },
      "Expiration": {
        "Days": 7
      }
    },
    {
      "ID": "archive-old-assets",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "assets/"
      },
      "Transitions": [
        {
          "Days": 90,
          "StorageClass": "GLACIER"
        }
      ]
    },
    {
      "ID": "delete-abandoned-drafts",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "assets/",
        "Tag": {
          "Key": "status",
          "Value": "draft"
        }
      },
      "Expiration": {
        "Days": 30
      }
    }
  ]
}

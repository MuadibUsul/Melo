# ─────────────────────────────────────────────────────────────────────────────
# minimax-music-platform — environment template (root: infra / api / worker)
# Copy to .env. NEVER commit real secrets. Server-only secrets are never NEXT_PUBLIC_*.
# Web-app env lives in apps/web/.env.local (see apps/web/.env.example).
# ─────────────────────────────────────────────────────────────────────────────

# --- Core infra (matches infra/docker-compose.yml defaults) ---
DATABASE_URL=postgresql://app:app@localhost:5433/music?schema=public
REDIS_URL=redis://localhost:6379

# --- Object storage (S3-compatible: MinIO locally, R2/OSS/COS in prod) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=music-assets
S3_PUBLIC_BASE_URL=

# --- MiniMax (server-only; see packages/sdk-minimax) ---
# Global: https://api.minimax.io | China: https://api.minimaxi.chat | US-West: https://api-uw.minimax.io
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Service wiring ---
API_PORT=4000
API_BASE_URL=http://localhost:4000

# --- Payments (placeholders; one real channel wired in Phase 2B) ---
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
